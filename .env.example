# Database
DB_USER=skadmin
DB_PASSWORD=skpassword
DB_NAME=sk_associates
DATABASE_URL=postgresql://skadmin:skpassword@localhost:5432/sk_associates

# JWT
JWT_SECRET=change_this_secret_in_production_min_32_chars
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=4000
NODE_ENV=development

# Mobile (Expo)
EXPO_PUBLIC_API_URL=http://localhost:4000/api/v1
